//! $RTH={"type":"gui"}

const { app, BrowserWindow } = WApplication;

let mainWindow;

process.title = 'Countdown';

app.on('ready', () => {
    mainWindow = new BrowserWindow({
        mica: false
    });
    mainWindow.load('./window.js');

    mainWindow.on('closed', () => {
        mainWindow = null;
    });
})

try {
    await app.executeAsync();
} catch (err) {
    console.error('App crashed:', err);
}